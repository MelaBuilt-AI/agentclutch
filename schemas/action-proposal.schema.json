{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentclutch.dev/schemas/action-proposal.schema.json",
  "title": "AgentClutch Action Proposal v0",
  "type": "object",
  "required": [
    "type",
    "id",
    "loopId",
    "stepId",
    "createdAt",
    "sourceMode",
    "agent",
    "proposedAction",
    "loopContext",
    "evidence"
  ],
  "properties": {
    "type": { "const": "agentclutch.action_proposal.v0" },
    "id": { "type": "string", "minLength": 1 },
    "loopId": { "type": "string", "minLength": 1 },
    "stepId": { "type": "string", "minLength": 1 },
    "createdAt": { "type": "string", "format": "date-time" },
    "sourceMode": {
      "enum": ["prompt_guard", "tool_wrapper", "loop_native"]
    },
    "agent": {
      "type": "object",
      "required": ["runtime"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "runtime": {
          "enum": [
            "playwright",
            "browser-use",
            "mcp",
            "cli",
            "desktop",
            "openai-agents",
            "langgraph",
            "custom"
          ]
        },
        "model": { "type": "string" },
        "version": { "type": "string" }
      },
      "additionalProperties": false
    },
    "userGoal": {
      "type": "object",
      "properties": {
        "summary": { "type": "string" },
        "original": { "type": "string" }
      },
      "additionalProperties": false
    },
    "proposedAction": {
      "type": "object",
      "required": ["kind", "label", "targetSurface"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "targetSurface": { "type": "string", "minLength": 1 },
        "targetApp": { "type": "string" },
        "targetIdentifier": { "type": "string" },
        "rawInput": true
      },
      "additionalProperties": false
    },
    "visibleContext": {
      "type": "object",
      "properties": {
        "pageTitle": { "type": "string" },
        "url": { "type": "string" },
        "selectedText": { "type": "string" },
        "highlightedSelector": { "type": "string" },
        "fields": { "type": "object" },
        "screenshotRef": { "type": "string" }
      },
      "additionalProperties": false
    },
    "loopContext": {
      "type": "object",
      "required": ["previousStepIds"],
      "properties": {
        "previousStepIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "planSummary": { "type": "string" },
        "whyNow": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "riskHints": {
      "type": "object",
      "properties": {
        "reversibility": {
          "enum": [
            "clean",
            "compensable",
            "residue",
            "not_reversible",
            "unknown"
          ]
        },
        "blastRadius": {
          "enum": [
            "none",
            "single_user",
            "team",
            "customer",
            "organization",
            "external",
            "public",
            "production"
          ]
        },
        "requiresApproval": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "source"],
        "properties": {
          "label": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "minLength": 1 },
          "summary": { "type": "string" },
          "hash": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "metadata": { "type": "object" }
  },
  "additionalProperties": false
}
