{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentclutch.dev/schemas/clutch-decision.schema.json",
  "title": "AgentClutch Clutch Decision v0",
  "oneOf": [
    {
      "type": "object",
      "required": ["type", "approvedBy", "decidedAt"],
      "properties": {
        "type": { "const": "approve_once" },
        "approvedBy": { "type": "string", "minLength": 1 },
        "decidedAt": { "type": "string", "format": "date-time" },
        "note": { "type": "string" }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": ["type", "approvedBy", "decidedAt", "patch"],
      "properties": {
        "type": { "const": "edit" },
        "approvedBy": { "type": "string", "minLength": 1 },
        "decidedAt": { "type": "string", "format": "date-time" },
        "patch": {
          "type": "array",
          "items": { "$ref": "#/$defs/actionPatch" }
        },
        "note": { "type": "string" }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": ["type", "blockedBy", "decidedAt", "reason"],
      "properties": {
        "type": { "const": "block" },
        "blockedBy": { "type": "string", "minLength": 1 },
        "decidedAt": { "type": "string", "format": "date-time" },
        "reason": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": ["type", "operator", "decidedAt", "resumeMode"],
      "properties": {
        "type": { "const": "takeover" },
        "operator": { "type": "string", "minLength": 1 },
        "decidedAt": { "type": "string", "format": "date-time" },
        "resumeMode": {
          "enum": [
            "resume_from_current_state",
            "resume_with_new_instruction",
            "stop_after_takeover"
          ]
        },
        "note": { "type": "string" }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": ["type", "approvedBy", "decidedAt", "rule"],
      "properties": {
        "type": { "const": "create_rule" },
        "approvedBy": { "type": "string", "minLength": 1 },
        "decidedAt": { "type": "string", "format": "date-time" },
        "rule": { "$ref": "#/$defs/clutchRule" },
        "note": { "type": "string" }
      },
      "additionalProperties": false
    }
  ],
  "$defs": {
    "actionPatch": {
      "type": "object",
      "required": ["op", "path"],
      "properties": {
        "op": { "enum": ["replace", "add", "remove"] },
        "path": { "type": "string", "minLength": 1 },
        "from": true,
        "value": true,
        "reason": { "type": "string" }
      },
      "additionalProperties": false
    },
    "clutchRule": {
      "type": "object",
      "required": ["id", "description", "match", "decision"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "match": { "type": "object" },
        "decision": { "enum": ["allow", "require_clutch", "block"] }
      },
      "additionalProperties": false
    }
  }
}
