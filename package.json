{
  "name": "agentclutch-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "AgentClutch: the open Action Card and takeover UX for consequential AI agent actions.",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "eslint .",
    "dev": "turbo run dev --parallel",
    "demo:checkout": "node --import tsx packages/cli/src/index.ts demo checkout",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,css}\""
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/node": "latest",
    "eslint": "latest",
    "globals": "^17.7.0",
    "playwright": "1.61.1",
    "prettier": "latest",
    "tsx": "latest",
    "turbo": "latest",
    "typescript": "latest",
    "typescript-eslint": "^8.62.0",
    "vitest": "latest"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
