{
  "name": "@agentclutch/cli",
  "version": "0.7.3-alpha.2",
  "description": "CLI for AgentClutch demos and local run inspection.",
  "license": "Apache-2.0",
  "type": "module",
  "keywords": [
    "agentclutch",
    "cli",
    "ai-agents",
    "human-in-the-loop",
    "playwright"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MelaBuilt-AI/agentclutch.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/MelaBuilt-AI/agentclutch#readme",
  "bugs": {
    "url": "https://github.com/MelaBuilt-AI/agentclutch/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public",
    "tag": "alpha"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agentclutch": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node --import tsx src/index.ts",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@agentclutch/playwright": "workspace:*",
    "@agentclutch/recorder": "workspace:*",
    "playwright": "1.61.1"
  }
}
