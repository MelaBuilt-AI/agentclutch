{
  "name": "@agentclutch/react",
  "version": "0.7.3-alpha.2",
  "description": "React-compatible components for AgentClutch Action Cards and takeover UX.",
  "license": "Apache-2.0",
  "type": "module",
  "keywords": [
    "agentclutch",
    "react",
    "action-card",
    "human-in-the-loop",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MelaBuilt-AI/agentclutch.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/MelaBuilt-AI/agentclutch#readme",
  "bugs": {
    "url": "https://github.com/MelaBuilt-AI/agentclutch/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public",
    "tag": "alpha"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./styles.css": "./src/styles.css"
  },
  "files": [
    "dist",
    "src/styles.css"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@agentclutch/action-card": "workspace:*",
    "@agentclutch/loop": "workspace:*"
  }
}
